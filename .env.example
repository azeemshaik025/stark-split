# Supabase (required for groups, expenses, settlements)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Starknet
NEXT_PUBLIC_STARKNET_NETWORK=sepolia
NEXT_PUBLIC_STAKING_CONTRACT=0x00ca1702e64c81d9a07b86bd2c540188d92a2c73cf5cc0e508d949015e7e84a7
# Optional: Custom RPC URL (Alchemy, Infura, etc.) — overrides default Cartridge RPC for balance fetches and transactions
# NEXT_PUBLIC_STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_KEY

# App (for invite links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Override displayed APR (default 7.25). Source: starknet.io/staking, stakingrewards.com
NEXT_PUBLIC_ESTIMATED_APR=7.25

# Faucet (server-only, for Settings page "Get 0.001 WBTC" button)
# Braavos wallet private key that holds WBTC to distribute. One request per address per 24h.
# FAUCET_PRIVATE_KEY=0x...
# FAUCET_PUBLIC_KEY=0x...
